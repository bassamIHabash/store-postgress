{
  "name": "storefront_backend",
  "version": "0.1.0",
  "description": "",
  "main": "server.ts",
  "scripts": {
    "start": "node dist/index.js",
    "start:dev": "tsc && node dist/index.js",
    "watch": "tsc-watch --esModuleInterop src/index.ts --outDir ./dist --onSuccess \"node ./dist/index.js\"",
    "build": "tsc",
    "test": "ENV=test npx db-migrate up --env test && tsc && ENV=test npx jasmine --config=spec/support/jasmine_dist.json",
    "test:clean": "ENV=test npx db-migrate reset --env test",
    "tsc": "tsc",
    "db:migrate": "npx db-migrate up",
    "db:rollback": "npx db-migrate down -c 4"
  },
  "author": "Udacity",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^1.19.0",
    "db-migrate": "^0.11.14",
    "db-migrate-pg": "^1.5.2",
    "dotenv": "^17.4.2",
    "express": "^4.17.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.5.1",
    "typescript": "^4.1.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.9",
    "@types/jasmine": "^3.6.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^16.18.126",
    "@types/pg": "^7.14.7",
    "@types/supertest": "^7.2.0",
    "jasmine": "^3.6.4",
    "jasmine-spec-reporter": "^6.0.0",
    "jasmine-ts": "^0.3.0",
    "supertest": "^7.2.2",
    "ts-node": "^9.1.1",
    "tsc-watch": "^4.2.9"
  }
}
